# Required — backend will not start without these
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CTA_TRAIN_API_KEY=your_cta_train_api_key_here
CTA_BUS_API_KEY=your_cta_bus_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional — production tuning (safe defaults used if omitted)
ALLOWED_ORIGINS=http://localhost:5173          # Comma-separated CORS allowlist; defaults to * in dev
BYOK_ENABLED=false                             # Allow users to supply their own Anthropic API key
RATE_LIMIT_ENABLED=false                       # Per-IP sliding-window limiter on /recommend
RESPONSE_CACHE_ENABLED=true                    # Set false to bypass the /recommend TTL cache (saves ~5–25 MB RAM; useful while traffic is low)
RATE_LIMIT_RPM=10                              # Requests per minute limit (if rate limiting enabled)
RATE_LIMIT_RPH=50                              # Requests per hour limit (if rate limiting enabled)
CLAUDE_SIMPLE_MODEL=claude-haiku-4-5-20251001  # Haiku-class model override
CLAUDE_COMPLEX_MODEL=claude-sonnet-4-6         # Sonnet-class model override
DAU_ADMIN_TOKEN=your_secret_token_here         # Protects all /admin/* analytics endpoints (dau, geography, sessions, hourly, devices, referrers)
DAILY_SALT=                                    # Daily-rotating HMAC salt for DAU and FEAT-001 sessions; production-required
PORT=8000                                      # Uvicorn port (Railway sets this automatically)

# Optional — FEAT-003 (geography). Leave empty to disable per-city counting.
MAXMIND_LICENSE_KEY=                           # Free key from maxmind.com; used by Dockerfile (prod) and scripts/fetch_geolite.py (local) to download GeoLite2-City
MAXMIND_DB_PATH=                               # Optional local-dev override path to a GeoLite2-City.mmdb file

# Optional — CTA API overrides (used mainly in tests)
CTA_TRAIN_API_URL=
CTA_BUS_API_URL=

# Optional — LocationIQ geocoding fallback (Tier 5 of the local-first cascade)
LOCATIONIQ_API_KEY=your_locationiq_api_key_here   # Missing key silently disables Tier 5 (local-only behavior)
LOCATIONIQ_ENABLED=true                           # Set false to disable Tier 5 entirely (privacy / kill switch)
LOCATIONIQ_DAILY_CAP=4900                         # UTC-day call ceiling; silent degrade to local-only when hit (~100-call headroom under 5,000/day free tier)

# Optional — Dockerfile downloads street graph from this URL at build time
STREET_GRAPH_URL=
