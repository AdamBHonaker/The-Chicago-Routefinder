# Required — backend will not start without these
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CTA_TRAIN_API_KEY=your_cta_train_api_key_here
CTA_BUS_API_KEY=your_cta_bus_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional — production tuning (safe defaults used if omitted)
ALLOWED_ORIGINS=http://localhost:5173          # Comma-separated CORS allowlist; defaults to * in dev
BYOK_ENABLED=false                             # Allow users to supply their own Anthropic API key
RATE_LIMIT_ENABLED=false                       # Per-IP sliding-window limiter on /recommend
RATE_LIMIT_RPM=10                              # Requests per minute limit (if rate limiting enabled)
RATE_LIMIT_RPH=50                              # Requests per hour limit (if rate limiting enabled)
CLAUDE_SIMPLE_MODEL=claude-haiku-4-5-20251001  # Haiku-class model override
CLAUDE_COMPLEX_MODEL=claude-sonnet-4-6         # Sonnet-class model override
DAU_ADMIN_TOKEN=your_secret_token_here         # Protects GET /admin/dau
PORT=8000                                      # Uvicorn port (Railway sets this automatically)

# Optional — CTA API overrides (used mainly in tests)
CTA_TRAIN_API_URL=
CTA_BUS_API_URL=

# Optional — Dockerfile downloads street graph from this URL at build time
STREET_GRAPH_URL=
