# Copy this file to .env.local for local development (never commit .env.local).
# Vite bakes VITE_* values into the bundle at build time.
#
# Required: set to your deployed backend URL in production (TD-019).
# In development this defaults to http://localhost:8000 in the app code,
# but explicit configuration here is preferred.
VITE_BACKEND_URL=http://localhost:8000

# Optional: set to "true" to enable the Bring-Your-Own-Key AI panel.
# The backend must also have BYOK_ENABLED=true to honour the forwarded key.
VITE_BYOK_ENABLED=false

# House ad (Phase 1 monetization). Default OFF in dev. Flip to "true" in
# Vercel after confirming the slot reads as part of the editorial column.
# URL and TEXT are env-driven so the affiliate target can be swapped without
# a redeploy. Leave blank when disabled.
VITE_HOUSE_AD_ENABLED=false
VITE_HOUSE_AD_URL=
VITE_HOUSE_AD_TEXT=
