# Environment variables — never commit API keys
.env
.env.local
backend/.env
frontend/.env.local

# CTA GTFS data — large files, re-downloaded via fetch_gtfs.py
backend/gtfs_data/

# Persistent geocode cache — built up at runtime from Google Maps API lookups
backend/geocode_cache.json
backend/geocode_cache.journal
backend/geocode_cache.tmp

# Monthly Google Maps API call counter — temporary pre-deployment rate limiter
backend/geocode_counter.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Node / React
node_modules/
dist/
frontend/dist/

# OS
.DS_Store
Thumbs.db

# Claude Code tooling
.claude/

# PDF documentation (large, available externally)
*.pdf

# Overpass/OSM API cache — re-built at runtime
backend/cache/
