# Environment variables — never commit API keys
.env
.env.local
backend/.env
frontend/.env.local

# CTA GTFS data — large files, re-downloaded via fetch_gtfs.py
backend/gtfs_data/

# FEAT-018 schedule index — large build artifact (~30 MB) regenerated locally
# via scripts/build_schedule_index.py after every GTFS refresh. The _README.md
# is kept tracked so contributors know what the directory is for.
backend/schedule_data/*.json
!backend/schedule_data/_README.md

# MaxMind GeoLite2 City database — large file, updated periodically by fetch_geolite.py
backend/GeoLite2-City.mmdb

# Legacy persistent geocode cache (Google Maps era) — code reading it was
# removed in Chunk 5 of the Geocoding & Autocomplete plan (2026-05-14); the
# on-disk file is absorbed into chicago_geocode.db.cached_forward by
# scripts/migrate_geocode_cache.py and deleted via its --cleanup flag. Kept
# gitignored until the maintainer runs --cleanup.
backend/geocode_cache.json
backend/geocode_cache.journal
backend/geocode_cache.tmp

# Legacy monthly Google Maps call counter — retired in Chunk 5 in favor of
# LocationIQ's LOCATIONIQ_DAILY_CAP + 429 circuit breaker + negative cache.
# Kept gitignored until --cleanup deletes the on-disk file.
backend/geocode_counter.json

# One-shot migration marker written by scripts/migrate_geocode_cache.py.
# Local-only state — the migrator refuses to re-run when it exists.
# Committing it would block the migration on any other dev machine.
backend/.geocode_cache_migrated

# Local-first geocoder SQLite store + WAL/SHM sidecars — built quarterly by
# scripts/build_address_points.py + build_intersections.py. Large derived
# artifact; never committed. The .sha256 sidecar is computed locally before
# each upload to the `geocode-db` GitHub Release; it's not the trusted hash
# (that role belongs to the asset on the release) so it has no business in
# git either.
backend/static_data/chicago_geocode.db
backend/static_data/chicago_geocode.db-wal
backend/static_data/chicago_geocode.db-shm
backend/static_data/chicago_geocode.db.sha256

# Runtime analytics counter outputs — the analytics modules write per-day
# aggregates to backend/data/ in dev (sibling to the modules) and to /app/data
# on Railway (persistent volume). Static fixtures live in backend/static_data/.
# Do NOT commit anything in backend/data/ — production volume overlays it
# anyway, and committed stubs hide image-baked fixtures behind the mount.
backend/data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
# Shell misparse artefact: `pip install pkg>=X.Y` without quoting writes a file
# named `=X.Y` in the cwd. Ignore any such files in the repo root or backend/.
=*

# Node / React
node_modules/
dist/
frontend/dist/

# OS
.DS_Store
Thumbs.db

# Claude Code tooling
.claude/

# PDF documentation (large, available externally)
*.pdf

# Private working folder — strategy/planning notes not for the public repo
Implementation Plans/

# Design artifacts — mockups and prototypes, all shipped; not useful to repo consumers
Design Documents/

# Personal workflow notes — local to this machine, not for the public repo
Human Documentation/

# Archived history logs — personal reference only
docs/archive/

# Pre-built street-network graphs — large derived artifacts.
# graphml is the OSMnx source (built locally by fetch_street_graph.py).
# pkl is the igraph runtime form, fetched at Docker build from the
# "street-graph" GitHub Release.
backend/street_graph.graphml
backend/street_graph_igraph.pkl

# Overpass/OSM API cache — re-built at runtime
# (covers both backend/cache/ and a top-level cache/ created when the script is
# run from the project root)
cache/
backend/cache/
backend/.overpass_cache.json

# Editor / IDE local settings
.vscode/
